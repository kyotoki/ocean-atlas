# Local Docker Compose secrets. Copy to .env (gitignored) and fill in real
# values before running `docker compose up` - do not commit the real .env.
#
# These are local-only MinIO root credentials (this month's stand-in for a
# real Cloudflare R2 bucket, per backend/.env.example) - generate strong
# random values rather than leaving MinIO's minioadmin/minioadmin default:
#   python3 -c "import secrets,string; a=string.ascii_letters+string.digits; print('MINIO_ROOT_USER=svel_'+''.join(secrets.choice(a) for _ in range(20))); print('MINIO_ROOT_PASSWORD='+''.join(secrets.choice(a) for _ in range(40)))"

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
