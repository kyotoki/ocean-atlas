EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Backend API base URL. Unset -> http://localhost:8000 (web/iOS simulator) or
# http://10.0.2.2:8000 (Android emulator), same as before this var existed.
# local Docker value for now - swap for the real (svel.app) URL in Month 4, not before.
EXPO_PUBLIC_API_URL=http://localhost:8000

# Error monitoring (utils/sentry.ts). Not secret (DSNs are meant to be
# embedded client-side) but unset locally on purpose - real values are set
# per build profile in eas.json, not here, since that's where native builds
# actually pull their env vars from.
EXPO_PUBLIC_SENTRY_DSN=
# Unset -> "development". Set to "staging"/"production" per eas.json build profile.
EXPO_PUBLIC_SENTRY_ENVIRONMENT=

# Analytics (utils/analytics.ts). One PostHog project total, tagged with
# EXPO_PUBLIC_SENTRY_ENVIRONMENT above to distinguish staging/production
# events - same "not secret, but set per eas.json build profile" pattern as
# the Sentry vars.
EXPO_PUBLIC_POSTHOG_KEY=
