{
  "expo": {
    "name": "Svel",
    "slug": "svel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/svellogo.jpg",
    "scheme": "svel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/svellogo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0B3D91"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.svel.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/svellogo.jpg",
        "backgroundColor": "#0B3D91"
      },
      "package": "com.svel.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/svellogo.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Svel uses your photo library so you can attach a picture to a logged dive.",
          "cameraPermission": "Svel uses your camera so you can take a photo to attach to a logged dive."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0B3D91"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d3a16dc1-94ce-4428-8197-6d465281e0b6"
      }
    },
    "owner": "svelapp"
  }
}
